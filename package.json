    "domain-modeling",
    "ir",
    "compiler",
    "runtime",
    "code-generation",
    "projections",
    "business-rules",
    "state-machine",
    "manifest"
  ],
  "type": "module",
  "license": "MIT",
  "private": false,
  "main": "./dist/manifest/runtime-engine.js",

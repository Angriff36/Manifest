{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@angriff36/manifest/*": ["../../dist/manifest/*"],
      "@angriff36/manifest": ["../../dist/manifest/runtime-engine.d.ts"],
      "@angriff36/manifest/compiler": ["../../dist/manifest/compiler.d.ts"],
      "@angriff36/manifest/ir-compiler": ["../../dist/manifest/ir-compiler.d.ts"],
      "@angriff36/manifest/ir": ["../../dist/manifest/ir.d.ts"],
      "@angriff36/manifest/projections/nextjs": ["../../dist/manifest/projections/nextjs/generator.d.ts"],
      "@angriff36/manifest/projections/routes": ["../../dist/manifest/projections/routes/generator.d.ts"],
      "@angriff36/manifest/registry/emit": ["../../dist/manifest/registry/emit.d.ts"],
      "@angriff36/manifest/audit": ["../../dist/manifest/audit/audit-sink.d.ts"],
      "@angriff36/manifest/audit/memory": ["../../dist/manifest/audit/sinks/memory.d.ts"],
      "@angriff36/manifest/audit/postgres": ["../../dist/manifest/audit/sinks/postgres.d.ts"],
      "@angriff36/manifest/outbox": ["../../dist/manifest/outbox/outbox-store.d.ts"],
      "@angriff36/manifest/outbox/memory": ["../../dist/manifest/outbox/stores/memory.d.ts"],
      "@angriff36/manifest/outbox/postgres": ["../../dist/manifest/outbox/stores/postgres.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.bench.ts",
    "src/checks/*.test.ts",
    "src/commands/*.test.ts",
    "src/utils/*.test.ts",
    "src/audit/*.test.ts"
  ]
}

import 'dart:typed_data';
import 'package:dio/dio.dart';

/// Async HTTP client for the Manifest API.
class ManifestClient {
  final Dio _dio;
  final String baseUrl;

  ManifestClient({
    String? baseUrl,
    Dio? dio,
    String? apiKey,
  })  : baseUrl = baseUrl ?? 'http://localhost:3000',
        _dio = dio ?? Dio() {
    _dio.options.baseUrl = baseUrl;
    if (apiKey != null) {
      _dio.options.headers['Authorization'] = 'Bearer ' + apiKey;
    }
  }

  /// List all Task entities.
  Future<List<Task>> listTasks() async {
    final response = await _dio.get('/api/tasks');
    final List<dynamic> data = response.data as List<dynamic>;
    return data.map((json) => Task.fromJson(json as Map<String, dynamic>)).toList();
  }

  /// Get a single Task by id.
  Future<Task> getTask(String id) async {
    final response = await _dio.get('/api/tasks/' + id);
    return Task.fromJson(response.data as Map<String, dynamic>);
  }

  /// Delete a Task by id.
  Future<void> deleteTask(String id) async {
    await _dio.delete('/api/tasks/' + id);
  }

  /// List all User entities.
  Future<List<User>> listUsers() async {
    final response = await _dio.get('/api/users');
    final List<dynamic> data = response.data as List<dynamic>;
    return data.map((json) => User.fromJson(json as Map<String, dynamic>)).toList();
  }

  /// Get a single User by id.
  Future<User> getUser(String id) async {
    final response = await _dio.get('/api/users/' + id);
    return User.fromJson(response.data as Map<String, dynamic>);
  }

  /// Delete a User by id.
  Future<void> deleteUser(String id) async {
    await _dio.delete('/api/users/' + id);
  }

  /// Execute command: updateStatus on Task
  Future<void> updateStatus(UpdateStatusParams params) async {
    final response = await _dio.post(
      '/api/tasks/\${params.id ?? ""}/update_status',
      data: params.toJson(),
    );
  }

  /// Execute command: assignTask on Task
  Future<void> assignTask(AssignTaskParams params) async {
    final response = await _dio.post(
      '/api/tasks/\${params.id ?? ""}/assign_task',
      data: params.toJson(),
    );
  }

  void close() {
    _dio.close();
  }
}",

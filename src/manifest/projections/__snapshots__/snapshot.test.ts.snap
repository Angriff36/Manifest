{
  "drizzle.schema": "// Auto-generated by @manifest/projection-drizzle
// DO NOT EDIT — regenerate with the projection.

import { pgTable } from 'drizzle-orm/pg-core';
import { integer, timestamp, varchar } from 'drizzle-orm/pg-core';
import { relations } from 'drizzle-orm';

export const task = pgTable("task", {
  id: varchar("id", { length: 255 }).primaryKey(),
  title: varchar("title", { length: 255 }).notNull().default(""),
  status: varchar("status", { length: 255 }).notNull().default("todo"),
  priority: integer("priority").default(1),
  assigneeId: varchar("assigneeId", { length: 255 }),
  createdAt: timestamp("createdAt"),
});

export const user = pgTable("user", {
  id: varchar("id", { length: 255 }).primaryKey(),
  name: varchar("name", { length: 255 }).notNull(),
  email: varchar("email", { length: 255 }).notNull().unique(),
  role: varchar("role", { length: 255 }).notNull().default("member"),
});

export const taskRelations = relations(task, ({ one, many }) => ({
  assignee: one(user, { fields: [task.assigneeId], references: [user.id] }),
}));

export const userRelations = relations(user, ({ one, many }) => ({
  tasks: many(task),
}));",
}
`;


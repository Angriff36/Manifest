}
",
  "health.handler": "/**
 * Generated Manifest health check handler.
 * Do not edit manually — regenerate from IR.
 *
 * Checks: IR integrity, store connectivity, outbox queue depth.
 * Compatible with Kubernetes liveness/readiness probes.
 */

export type HealthStatus = 'healthy' | 'degraded' | 'unhealthy';

export interface ComponentHealth {
  status: HealthStatus;
  message?: string;
  details?: Record<string, unknown>;
}

export interface HealthReport {
  status: HealthStatus;
  timestamp: string;
  checks: {
    ir: ComponentHealth;
    stores: Record<string, ComponentHealth>;
  };
}

/** Baked IR provenance from compilation. */
const MANIFEST_IR_META = {
  contentHash: 'snapshot-fixture-hash',
  compilerVersion: 'snapshot-test',
  schemaVersion: '1.0',
  compiledAt: '2025-01-01T00:00:00.000Z',
} as const;

/**
 * Check IR integrity by validating provenance hash.
 * TODO: Implement live hash computation against loaded IR.
 */
function checkIR(): ComponentHealth {
  return { status: 'healthy', message: 'IR provenance verified', details: MANIFEST_IR_META };
}

/**
 * Check connectivity for durable stores.
 * TODO: Implement actual durable connectivity check.
 */
async function checkDurableStore(): Promise<ComponentHealth> {
  try {
    // TODO: Add durable connection health check
    // Example: await pool.query('SELECT 1') or equivalent
    return { status: 'healthy', message: 'durable store connected' };
  } catch (error) {
    return { status: 'unhealthy', message: 'durable store unreachable', details: { error: String(error) } };
  }
}

/**
 * Run all health checks and return an aggregated report.
 *
 * Status logic:
 *   - 'healthy'   — all checks pass
 *   - 'degraded'  — some non-critical checks fail (stores)
 *   - 'unhealthy' — IR check fails or all stores unreachable
 */
export async function runHealthCheck(): Promise<HealthReport> {
  const checks: HealthReport['checks'] = {} as HealthReport['checks'];
  let overallStatus: HealthStatus = 'healthy';

  // IR integrity
  const irHealth = checkIR();
  (checks as Record<string, unknown>).ir = irHealth;
  if (irHealth.status === 'unhealthy') {
    overallStatus = 'unhealthy';
  }

  // Store connectivity
  const storeResults: Record<string, ComponentHealth> = {};
  storeResults['durable'] = await checkDurableStore();
  (checks as Record<string, unknown>).stores = storeResults;

  const storeStatuses = Object.values(storeResults);
  const anyStoreUnhealthy = storeStatuses.some(s => s.status === 'unhealthy');
  const allStoresUnhealthy = storeStatuses.every(s => s.status === 'unhealthy');
  if (allStoresUnhealthy && overallStatus !== 'unhealthy') {
    overallStatus = 'unhealthy';
  } else if (anyStoreUnhealthy && overallStatus === 'healthy') {
    overallStatus = 'degraded';
  }

  return {
    status: overallStatus,
    timestamp: new Date().toISOString(),
    checks,
  };
}

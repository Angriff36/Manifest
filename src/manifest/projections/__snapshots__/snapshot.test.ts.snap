exports[`projection snapshots > sveltekit > generated artifacts match snapshot 1`] = `
{
  "sveltekit.client": "/**
 * Auto-generated SvelteKit $lib client utilities for SvelteKit
 * Generated from Manifest IR — DO NOT EDIT
 * Generated at: 2025-01-01T00:00:00.000Z
 *
 * Writes flow through the Manifest runtime to enforce
 * guards, policies, and constraints. Reads MAY bypass the runtime
 * when a database client is configured.
 *
 * Regenerate with: manifest generate <ir> -p sveltekit
 */

import type { ManifestActionResult, ManifestDiagnostic } from "./manifest-types";

/**
 * Invoke a Manifest command via the SvelteKit +server.ts dispatch route.
 * Use this from client components after \`enhance\` is not appropriate.
 */
export async function invokeManifestCommand<T = unknown>(
  entity: string,
  command: string,
  params: Record<string, unknown> = {},
  instanceId?: string,
  fetchImpl: typeof fetch = fetch,
): Promise<ManifestActionResult<T>> {
  const segment = entity
    .replace(/([a-z0-9])([A-Z])/g, "$1-$2")
    .toLowerCase();
  const response = await fetchImpl(\`/\${segment}\`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ command, params, instanceId }),
  });
  const payload = (await response.json().catch(() => ({}))) as ManifestActionResult<T>;
  if (!response.ok && payload.success === undefined) {
    return {
      success: false,
      error: (payload as unknown as { error?: string }).error ?? response.statusText,
      diagnostics: (payload as unknown as { diagnostics?: ManifestDiagnostic[] }).diagnostics ?? [],
    };
  }
  return payload;
}

/**
 * Normalize a runtime command result into the ManifestActionResult shape.
 */
export function normalizeCommandResult<T = unknown>(
  result: unknown,
): ManifestActionResult<T> {
  const r = result as Partial<ManifestActionResult<T>> & { error?: string };
  if (r && typeof r.success === "boolean") {
    return r as ManifestActionResult<T>;
  }
  return {
    success: !r?.error,
    data: r?.data as T | undefined,
    error: r?.error,
    events: r?.events ?? [],
    diagnostics: r?.diagnostics ?? [],
  };
}
",
  "sveltekit.load:Task": "/**
 * Auto-generated SvelteKit +page.server.ts loader for Task
 * Generated from Manifest IR — DO NOT EDIT
 * Generated at: 2025-01-01T00:00:00.000Z
 *
 * Writes flow through the Manifest runtime to enforce
 * guards, policies, and constraints. Reads MAY bypass the runtime
 * when a database client is configured.
 *
 * Regenerate with: manifest generate <ir> -p sveltekit
 */

import { error, redirect, fail } from "@sveltejs/kit";
import type { Actions, PageServerLoad } from "./$types";
import { database } from "$lib/server/database";
import { createManifestRuntime } from "$lib/server/manifest-runtime";
import { lucia } from "$lib/server/auth";

/**
 * SvelteKit PageServerLoad for the Task list page. Returns
 * type-safe \`PageData\` consumed by the corresponding +page.svelte.
 */
export const load: PageServerLoad = async (event) => {
  const session = event.locals.session;
  if (!session?.user?.id) {
    throw redirect(302, "/login");
  }
  const userId = session.user.id;

  const userMapping = await database.userTenantMapping.findUnique({
    where: { userId },
  });
  if (!userMapping) {
    throw error(400, "User not mapped to tenant");
  }
  const { tenantId } = userMapping;

  const tasks = await database.task.findMany({
    where: { tenantId },
    orderBy: { createdAt: "desc" },
  });

  return { tasks };
};

/**
 * SvelteKit form actions — POST-only handlers backing progressive
 * enhancement <form action="?/commandName" method="POST"> submissions.
 * Each action validates input via the Manifest runtime so guards, policies,
 * and constraints remain authoritative.
 */
export const actions: Actions = {
  /**
   * AssignTask command for Task.
   * Guards: 1 (evaluated in order, halts on first failure)
   *   [0] userId != ""
   * Policies: OnlyAssignee
   * Emits: TaskAssigned
   */
  assignTask: async (event) => {
    try {
  const session = event.locals.session;
  if (!session?.user?.id) {
    return json({ error: "Unauthorized", diagnostics: [] }, { status: 401 });
  }
  const userId = session.user.id;

  const userMapping = await database.userTenantMapping.findUnique({
    where: { userId },
  });
  if (!userMapping) {
    return json({ error: "User not mapped to tenant", diagnostics: [] }, { status: 400 });
  }
  const { tenantId } = userMapping;

      const formData = await event.request.formData();
      const params = Object.fromEntries(formData);
      const instanceId =
        (typeof params.instanceId === "string" ? params.instanceId : undefined) ??
        (typeof params.id === "string" ? params.id : undefined);

      const runtime = await createManifestRuntime({ user: { id: userId, tenantId } });
      const result = await runtime.runCommand("Task", "assignTask", {
        params,
        instanceId,
      });

      if (!result.success) {
        const firstDiagnostic = result.diagnostics?.[0];
        const status = firstDiagnostic?.kind === "policy_denial" ? 403
          : firstDiagnostic?.kind === "guard_failure" ? 422
          : firstDiagnostic?.kind === "constraint_block" ? 422
          : firstDiagnostic?.kind === "concurrency_conflict" ? 409
          : 400;
        return fail(status, {
          error: result.error,
          diagnostics: result.diagnostics,
        });
      }

      return {

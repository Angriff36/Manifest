{
  "elasticsearch.client": "/**
 * Elasticsearch typed search query builders.
 * Generated by Manifest — do not edit by hand.
 *
 * Provides typed search functions for each indexed entity.
 */

import type { ESClient } from './indexer';

/** Search query result */
export interface SearchResult<T> {
  hits: Array<{ _id: string; _source: T; _score: number }>;
  total: { value: number; relation: 'eq' | 'gte' };
}


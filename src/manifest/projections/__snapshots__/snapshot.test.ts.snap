",
  "elasticsearch.indexTemplate": "{
  "index_templates": {}
}
",
  "elasticsearch.indexer": "/**
 * Elasticsearch indexer worker — outbox-driven sync adapter.
 * Generated by Manifest — do not edit by hand.
 *
 * Consumes outbox entries and bulk-indexes entity state changes
 * into Elasticsearch. Uses the transactional outbox pattern to
 * guarantee at-least-once delivery and idempotent indexing.
 */

import type { OutboxStore, OutboxEntry } from '@manifest/outbox';

/** Elasticsearch bulk operation shape */
interface BulkOperation {
  index: { _index: string; _id: string };
}

interface BulkResponse {
  errors: boolean;
  items: Array<{ index?: { _id: string; status: number; error?: unknown } }>;
}

/** Minimal fetch-based ES client interface */
interface ESClient {
  bulk(body: string): Promise<BulkResponse>;
  ping(): Promise<boolean>;
}

/**
 * Run the Elasticsearch indexer loop.
 * Claims batches from the outbox and bulk-indexes them.
 */
export async function runElasticsearchIndexer(
  outboxStore: OutboxStore,
  client: ESClient,
  options?: { batchSize?: number; refresh?: string },
): Promise<void> {
  const batch = options?.batchSize ?? 100;
  const refresh = options?.refresh ?? "false";

  // Verify ES connectivity
  const alive = await client.ping();
  if (!alive) throw new Error('Elasticsearch is not reachable');

  // Claim and index in a loop
  const entries = await outboxStore.claim(batch);
  if (entries.length === 0) return;

  // Map outbox events to bulk index operations
  const operations = entries
    .filter((e) => e.event.entityName)
    .map((entry: OutboxEntry) => {
      const event = entry.event;
      const entityName = event.entityName;
      const doc = { ...event.payload, _indexed_at: new Date().toISOString() };
      return {
        index: { _index: entityName, _id: event.instanceId ?? entry.entryId },
        doc,
      };
    });

  if (operations.length === 0) {
    await outboxStore.markDelivered(entries.map((e) => e.entryId));
    return;
  }

  // Build bulk request body
  const body = operations
    .flatMap((op) => [
      JSON.stringify({ index: { _index: op.index._index, _id: op.index._id } }),
      JSON.stringify(op.doc),
    ])
    .join('\\n') + '\\n';

  // Execute with retry
  let attempts = 0;
  const maxAttempts = 3;
  while (attempts < maxAttempts) {
    try {
      const response = await client.bulk(body);
      if (response.errors) {
        const failedIds = response.items
          .filter((item) => item.index?.error)
          .map((item) => item.index!._id);
        if (failedIds.length > 0) {
          await outboxStore.markFailed(failedIds, 'Bulk index error');
        }
        const succeededIds = entries
          .map((e) => e.entryId)
          .filter((id) => !failedIds.includes(id));
        await outboxStore.markDelivered(succeededIds);
        return;
      } else {
        await outboxStore.markDelivered(entries.map((e) => e.entryId));
        return;
      }
    } catch (error) {
      attempts++;
      if (attempts >= maxAttempts) {
        const msg = error instanceof Error ? error.message : String(error);
        await outboxStore.markFailed(
          entries.map((e) => e.entryId),
          \`Indexing failed after \${attempts} attempts: \${msg}\`,
        );
        throw error;
      }
      // Exponential backoff: 100ms, 200ms, 400ms
      await new Promise((r) => setTimeout(r, 100 * Math.pow(2, attempts - 1)));
    }
  }
}
",

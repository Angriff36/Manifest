export function useTaskUpdateStatus(
  options?: Omit<UseMutationOptions<unknown, Error, TaskUpdateStatusInput>, 'mutationFn'>,
) {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: (input: TaskUpdateStatusInput) =>
      apiFetch<unknown>(\`/api/manifest/task/commands/update-status\`, {

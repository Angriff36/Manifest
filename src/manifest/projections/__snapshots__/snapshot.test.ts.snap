{
  "mermaid.er": "erDiagram
    Task {
        string id "PK"
        string title "PK"
        string status "PK"
        int priority "nullable"
        string assigneeId "nullable"
        datetime createdAt
    }
    Task }o--|| User : "assignee"
    User {
        string id "PK"
        string name "PK"
        string email "PK"
        string role "PK"
    }
    User ||--o{ Task : "tasks"",
  "mermaid.sequence.Task.assignTask": "sequenceDiagram
    participant Client
    participant Task as Task
    participant EventBus
    Client->>+Task: assignTask(userId)
    Note over Task: Guards (1)
    Task->>Task: guard[0]: userId != #quot;#quot;
    Task->>Task: mutate.assigneeId
    Task->>EventBus: emit TaskAssigned on tasks.assigned
    Task-->>-Client: void",
  "mermaid.sequence.Task.updateStatus": "sequenceDiagram
    participant Client
    participant Task as Task
    participant EventBus
    Client->>+Task: updateStatus(newStatus)
    Note over Task: Guards (1)
    Task->>Task: guard[0]: newStatus != #quot;#quot;
    Task->>Task: mutate.status
    Task->>EventBus: emit TaskStatusUpdated on tasks.updated
    Task-->>-Client: void",
}
`;


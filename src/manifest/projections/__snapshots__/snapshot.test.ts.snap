  options?: Omit<UseMutationOptions<unknown, Error, TaskUpdateStatusInput>, 'mutationFn'>,
) {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: (input: TaskUpdateStatusInput) =>

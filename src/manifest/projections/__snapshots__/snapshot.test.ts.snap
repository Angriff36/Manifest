const app = new Hono<Env>();

// --- User routes ---

  /** List all User entities */
  app.get('/user/list', requireAuth, async (c) => {
    const runtime = createManifestRuntime();
    const user = c.get('user');
    const result = await runtime.list('User', { tenantId: user.tenantId });
    return c.json(result);
  });

  /** Get a single User by ID */
  app.get('/user/:id', requireAuth, async (c) => {
    const id = c.req.param('id');
    const runtime = createManifestRuntime();
    const user = c.get('user');
    const result = await runtime.get('User', id, { tenantId: user.tenantId });
    if (!result) {
      return c.json({ error: { code: 'NOT_FOUND', message: 'User not found' } }, 404);
    }
    return c.json(result);
  });

export default app;

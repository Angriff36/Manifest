{
  "health.express": "/**
 * Generated Manifest health check — Express middleware.
 * Do not edit manually — regenerate from IR.
 *
 * Usage: app.get("/manifest/health", manifestHealthHandler);
 * Returns: { status, timestamp, checks }
 * HTTP 200 = healthy, HTTP 503 = unhealthy/degraded
 */

import { runHealthCheck } from '@/lib/manifest-health-handler';

import type { Request, Response } from 'express';

export async function manifestHealthHandler(_req: Request, res: Response): Promise<void> {

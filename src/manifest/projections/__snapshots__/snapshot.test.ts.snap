{
  "graphql.resolvers": "/**
 * Generated GraphQL resolver stubs from Manifest IR.
 * Reads use direct database queries for performance.
 * Writes use runtime.runCommand() to preserve policy/guard/constraint semantics.
 */

import { createManifestRuntime } from '@/lib/manifest-runtime';
import { database } from '@/lib/database';
import { PubSub } from 'graphql-subscriptions';

const pubsub = new PubSub();

export const queryResolvers = {
  tasks: async (_parent: unknown, _args: unknown, context: unknown) => {
    return database.task.findMany();
  },

  task: async (_parent: unknown, args: { id: string }, context: unknown) => {
    return database.task.findUnique({ where: { id: args.id } });
  },

  users: async (_parent: unknown, _args: unknown, context: unknown) => {
    return database.user.findMany();
  },

  user: async (_parent: unknown, args: { id: string }, context: unknown) => {
    return database.user.findUnique({ where: { id: args.id } });
  },

};

export const mutationResolvers = {
  taskAssignTask: async (_parent: unknown, args: { input: Record<string, unknown> }, context: unknown) => {
    const runtime = createManifestRuntime(context);
    return runtime.runCommand('Task', 'assignTask', args.input);
  },

  taskUpdateStatus: async (_parent: unknown, args: { input: Record<string, unknown> }, context: unknown) => {
    const runtime = createManifestRuntime(context);
    return runtime.runCommand('Task', 'updateStatus', args.input);
  },

};

export const subscriptionResolvers = {
  taskAssigned: {
    subscribe: () => pubsub.asyncIterableIterator('tasks.assigned'),
  },

  taskStatusUpdated: {
    subscribe: () => pubsub.asyncIterableIterator('tasks.updated'),
  },

};

export const resolvers = {
  Query: queryResolvers,
  Mutation: mutationResolvers,
  Subscription: subscriptionResolvers,
};
",
  "graphql.schema": "# Generated by Manifest GraphQL Projection

# Do not edit manually — regenerate from IR

scalar DateTime

directive @auth(requires: [String!]!) on OBJECT | FIELD_DEFINITION

"""Task entity"""
type Task @auth(requires: [EXECUTE]) {
  id: String!
  """Default: """""
  title: String!
  """Default: "todo""""
  status: String!
  """Default: 1"""
  priority: Int
  assigneeId: String
  createdAt: DateTime!
  """Computed: self.priority >= 3"""
  isHighPriority: Boolean!
  assignee: User
}

"""User entity"""
type User {
  id: String!
  name: String!
  """Unique"""
  email: String!
  """Default: "member""""
  role: String!
  tasks: [Task!]!
}

"""Payload for TaskAssigned event (channel: tasks.assigned)"""
type TaskAssignedPayload {
  id: String!
  userId: String!
}

"""Payload for TaskStatusUpdated event (channel: tasks.updated)"""
type TaskStatusUpdatedPayload {
  id: String!
  newStatus: String!
}

"""Input for Task.assignTask command"""
input TaskAssignTaskInput {
  userId: String!
}

"""Input for Task.updateStatus command"""
input TaskUpdateStatusInput {
  newStatus: String!
}

type Query {
  """List all Task entities"""
  tasks: [Task!]!
  """Get a single Task by ID"""
  task(id: ID!): Task
  """List all User entities"""
  users: [User!]!
  """Get a single User by ID"""
  user(id: ID!): User
}

type Mutation {
  """Execute assignTask on Task. Guards: 1 guard(s) evaluated in order"""
  taskAssignTask(input: TaskAssignTaskInput!): Task
  """Execute updateStatus on Task. Guards: 1 guard(s) evaluated in order"""
  taskUpdateStatus(input: TaskUpdateStatusInput!): Task
}

type Subscription {
  """Subscribe to TaskAssigned events (channel: tasks.assigned)"""
  taskAssigned: TaskAssignedPayload!
  """Subscribe to TaskStatusUpdated events (channel: tasks.updated)"""
  taskStatusUpdated: TaskStatusUpdatedPayload!
}
",
}
`;


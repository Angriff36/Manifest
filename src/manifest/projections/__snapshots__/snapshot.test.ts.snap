{
  "convex.mutations": "// GENERATED by the Manifest → Convex projection. DO NOT EDIT.
// 2 mutation(s); roles: 0; policies: 1.

import { mutation } from "./_generated/server";
import { v } from "convex/values";

// Role hierarchy from IR (effective permissions after inheritance).
const ROLE_PERMISSIONS: Record<string, string[]> = {};

function checkRole(userRole: string, action: string): boolean {
  const perms = ROLE_PERMISSIONS[userRole];
  return perms ? (perms.includes(action) || perms.includes("all")) : false;
}

// Feature toggle (configurable). Not an authorization gate.
function flag(_name?: string): boolean { return true; }

export const Task_updateStatus = mutation({
  args: {
    docId: v.id("tasks"),
    newStatus: v.string()
  },
  handler: async (ctx, { docId, newStatus }) => {
    const doc = await ctx.db.get(docId);
    if (!doc) throw new Error("Task not found");
    if (!((newStatus !== ""))) throw new Error("Guard 0 failed");
    const updates = {
      status: newStatus
    };
    await ctx.db.patch(docId, updates);
    const payload: Record<string, any> = { ...doc, ...updates };
    await ctx.db.insert("events", { type: "TaskStatusUpdated", entity: "Task", entityId: docId, payload: {}, createdAt: Date.now() });
    return { ...doc, ...updates };
  },
});

export const Task_assignTask = mutation({
  args: {
    docId: v.id("tasks"),
    userId: v.string()
  },
  handler: async (ctx, { docId, userId }) => {
    const doc = await ctx.db.get(docId);
    if (!doc) throw new Error("Task not found");
    if (!((userId !== ""))) throw new Error("Guard 0 failed");
    const updates = {
      assigneeId: userId
    };
    await ctx.db.patch(docId, updates);
    const payload: Record<string, any> = { ...doc, ...updates };
    await ctx.db.insert("events", { type: "TaskAssigned", entity: "Task", entityId: docId, payload: {}, createdAt: Date.now() });
    return { ...doc, ...updates };
  },
});
",

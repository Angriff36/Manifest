    return await ctx.db.query("tasks").collect();
  },
});

export const getTask = query({
  args: { id: v.id("tasks") },
  handler: async (ctx, { id }) => {
    return await ctx.db.get(id);
  },
});

export const listTaskByAssigneeId = query({
  args: { assigneeId: v.id("users") },
  handler: async (ctx, { assigneeId }) => {
    return await ctx.db.query("tasks").withIndex("by_assigneeId", (q) => q.eq("assigneeId", assigneeId)).collect();
  },
});

export const listUser = query({
  args: {},
  handler: async (ctx) => {
    return await ctx.db.query("users").collect();
  },
});


    queryKey: queryKeys.user.lists(),
    queryFn: () =>
      apiFetch<{ users: User[] }>(\`/api/user/list\`)
        .then(data => data.users),
    staleTime: 30000,
    ...options,
  });
}

export function useUserDetail(
  id: string,
  options?: Omit<UseQueryOptions<User, Error>, 'queryKey' | 'queryFn'>,
) {
  return useQuery({
    queryKey: queryKeys.user.detail(id),
    queryFn: () =>
      apiFetch<{ user: User }>(\`/api/user/\${encodeURIComponent(id)}\`)
        .then(data => data.user),
    enabled: !!id,
    staleTime: 30000,
    ...options,
  });
}

// ============================================================
// Command mutation hooks

{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Manifest",
  "description": "Deterministic, IR-first DSL for business rules and workflows. Current version: v0.6.1.",
  "colors": {
    "primary": "#0EA5E9",
    "light": "#38BDF8",
    "dark": "#0369A1"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "installation",
              "faq",
              "troubleshooting"
            ]
          },
          {
            "group": "Language Reference",
            "pages": [
              "language/entities",
              "language/commands",
              "language/computed-properties",
              "language/events",
              "language/guards-policies",
              "language/stores"
            ]
          },
          {
            "group": "Integration",
            "pages": [
              "integration/overview",
              "integration/embedded-runtime",
              "integration/projections",
              "integration/nextjs"
            ]
          },
          {
            "group": "Adapters",
            "pages": [
              "adapters/audit-sink",
              "adapters/outbox",
              "adapters/custom-stores"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/commands",
              "cli/governance",
              "cli/configuration"
            ]
          },
          {
            "group": "Specification (ir-v1)",
            "pages": [
              "spec/ir-v1/overview",
              "spec/ir-v1/semantics",
              "spec/ir-v1/builtins",
              "spec/ir-v1/adapters",
              "spec/ir-v1/conformance",
              "spec/ir-v1/vnext",
              "spec/ir-v1/registry"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/positioning",
              "architecture/deployment-boundaries",
              "architecture/house-style"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "migration/vnext-migration-guide"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Angriff36/Manifest",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Angriff36/Manifest"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Angriff36/Manifest"
    }
  }
}
